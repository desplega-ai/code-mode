{
  "compilerOptions": {
    "target": "esnext",
    "module": "preserve",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "jsx": "preserve",
    "types": ["bun"]
  },
  "include": ["bin/**/*.ts", "server/**/*.ts", "test/**/*.ts", "ui/**/*.ts", "ui/**/*.tsx"]
}
