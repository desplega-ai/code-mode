# Template for a shell env to source before invoking MCP-Bench with the
# Claude Code adapter. Copy to `.env.smoke` in your MCP-Bench fork and
# replace the placeholders. `source .env.smoke` before running
# `python run_benchmark.py ...`.
#
# Keep this file free of secrets — commit only the template.

# ─── Claude Code ────────────────────────────────────────────────────
# OAuth token. If you're running from the code-mode dev env, this
# pulls from the repo's own `bench/.env`:
export CLAUDE_CODE_OAUTH_TOKEN="$(grep '^CLAUDE_CODE_OAUTH_TOKEN=' /path/to/code-mode/bench/.env | cut -d= -f2- | tr -d '\"')"
# Or just set it directly:
# export CLAUDE_CODE_OAUTH_TOKEN="sk-ant-oat01-..."

export CLAUDE_CODE_MODEL="claude-sonnet-4-6"       # or claude-opus-4-6
export CLAUDE_CODE_TIMEOUT_S=900

# ─── code-mode plugin (only needed for codemode-block variant) ──────
export CODE_MODE_PLUGIN_DIR="/path/to/code-mode/plugins/code-mode"

# ─── Judge ──────────────────────────────────────────────────────────
# OPENAI_API_KEY is checked by judge-openai.patch; if unset, the judge
# falls back to Azure (requires AZURE_OPENAI_API_KEY/ENDPOINT).
# export OPENAI_API_KEY="sk-..."
# export OPENAI_BASE_URL=""                        # optional override
export JUDGE_MODEL="gpt-5-mini"                    # any chat-completions model

# ─── Debug ──────────────────────────────────────────────────────────
# Preserve per-task working directories under $TMPDIR/mcpbench-claude-*
# so you can inspect _stream.jsonl + _parsed.json after the run.
export CLAUDE_CODE_KEEP_WORKDIR=1
