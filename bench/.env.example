# Required: Claude Code OAuth token (forwarded into every container).
CLAUDE_CODE_OAUTH_TOKEN=

# Optional: override CLI defaults when flags are absent.
# BENCH_DEFAULT_CONCURRENCY=2
# BENCH_DEFAULT_REPS=3
# BENCH_DEFAULT_MODELS=claude-sonnet-4-6,claude-opus-4-6   # aliases ok: sonnet,opus

# Optional: any key prefixed BENCH_FORWARD_ is passed into the container
# with the prefix stripped. Example:
#   BENCH_FORWARD_GITHUB_TOKEN=ghp_xxx  ->  docker run -e GITHUB_TOKEN=ghp_xxx
# BENCH_FORWARD_GITHUB_TOKEN=
